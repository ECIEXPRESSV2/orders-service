# ─── General ───────────────────────────────────────────────
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
TZ=America/Bogota
SWAGGER_AUTO_OPEN=false

# ─── Base de datos (PostgreSQL / NeonDB, dedicada a orders) ──
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Bus de eventos (RabbitMQ / CloudAMQP, exchange compartido) ─
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=eciexpress_events
RABBITMQ_QUEUE=orders_service_queue

# ─── Servicios externos ──────────────────────────────────────
IDENTITY_SERVICE_URL=http://localhost:3001
PRODUCTS_SERVICE_URL=http://localhost:3002

# ─── Flags de integración ────────────────────────────────────
USE_PRODUCTS_MOCK=true
AUTH_DISABLED=false
